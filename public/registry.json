      "files": [
        {
          "path": "registry/default/ui/stepper.tsx",
          "type": "registry:ui",
          "target": "components/ui/stepper.tsx"
        },
        {
          "path": "registry/default/examples/stepper-demo.tsx",
          "type": "registry:component",
          "target": "components/stepper-demo.tsx"
        }
      ]
