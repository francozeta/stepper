{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check": {
      "dependsOn": ["registry:check", "lint", "typecheck", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "registry:build": {
      "outputs": [
        "registry/default/ui/**",
        "public/*.json"
      ]
    },
    "registry:check": {},
    "test": {},
    "typecheck": {
      "dependsOn": ["docs:source"]
    },
    "docs:source": {
      "outputs": [".source/**"]
    }
  }
}
