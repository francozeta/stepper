{
  "name": "@francozeta/stepper",
  "version": "0.1.5",
  "description": "A shadcn/ui-native Stepper primitive for real product flows.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./registry": "./registry/default/ui/stepper.tsx",
    "./registry.json": "./registry/default/ui/stepper.json"
  },
  "files": [
    "dist",
    "registry",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "stepper",
    "react",
    "nextjs",
    "tailwindcss",
    "shadcn",
    "wizard",
    "onboarding"
  ],
  "homepage": "https://stepper-hazel-sigma.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francozeta/stepper.git"
  },
  "bugs": {
    "url": "https://github.com/francozeta/stepper/issues"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
