{
  "name": "stepper",
  "version": "0.4.1",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "turbo run dev",
    "docs:source": "fumadocs-mdx",
    "build": "next build",
    "build:turbo": "turbo run build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "fumadocs-mdx",
    "registry:build": "node scripts/build-stepper-registry.mjs && shadcn build --output public",
    "registry:check": "node scripts/build-stepper-registry.mjs --check && shadcn build --output public",
    "package:build": "pnpm registry:build && tsup --config tsup.config.ts && pnpm package:build:css && pnpm package:check",
    "package:build:css": "tailwindcss -i packages/stepper/src/styles.css -o packages/stepper/dist/styles.css --minify",
    "package:check": "node scripts/check-stepper-package.mjs",
    "package:pack": "pnpm package:build && npm pack ./packages/stepper --dry-run",
    "package:publish": "pnpm release",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "test": "vitest run",
    "typecheck": "pnpm docs:source && tsc --noEmit",
    "check": "pnpm registry:check && pnpm lint && pnpm typecheck && pnpm test && pnpm package:build && pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "copy-to-clipboard": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.5.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "turbo": "^2.9.7",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
