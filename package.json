{
  "name": "stepper",
  "version": "0.7.2",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francozeta/stepper.git"
  },
  "bugs": {
    "url": "https://github.com/francozeta/stepper/issues"
  },
  "homepage": "https://francozeta-stepper.vercel.app",
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "turbo run dev",
    "docs:source": "fumadocs-mdx",
    "build": "next build",
    "build:turbo": "turbo run build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "fumadocs-mdx",
    "registry:build": "node scripts/build-stepper-registry.mjs && shadcn build --output public",
    "registry:check": "node scripts/build-stepper-registry.mjs --check && shadcn build --output public",
    "test": "vitest run",
    "typecheck": "pnpm docs:source && tsc --noEmit",
    "check": "pnpm registry:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "copy-to-clipboard": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "fumadocs-core": "^16.8.7",
    "fumadocs-mdx": "^14.3.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.1",
    "shadcn": "^4.6.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4",
    "turbo": "^2.9.7",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
